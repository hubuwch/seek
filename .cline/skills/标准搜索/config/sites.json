  "selection_rules": {
    "max_sites_per_domain": 3,
    "min_authority_score": 80,
    "prefer_local_sites": true,
    "language_preference": ["zh", "en"],
    "fallback_to_general": true,
    "combine_multiple_domains": true,
    "site_operator_format": "site:{domain}",
    "combine_operator": "OR"
  },
  
  "validation": {
    "check_site_availability": true,
    "update_frequency_days": 30,
    "auto_disable_failed_sites": true,
    "backup_sites_enabled": true
  }
